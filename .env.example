# Nginx public port.
LANDING_HTTP_PORT=80

# MySQL settings.
MYSQL_DATABASE=landing_pages
MYSQL_USER=landing
MYSQL_PASSWORD=change-me-landing-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Admin token for GET /api/leads.
LEADS_ADMIN_TOKEN=change-me-admin-token

# LandOm SDK event ingestion.
LANDOM_SDK_ENDPOINT=/api/v1/events
LANDOM_SDK_API_KEY=change-me-landom-sdk-key
ATTUNE_SDK_API_KEY=change-me-attune-sdk-key
SIAN_SDK_API_KEY=change-me-sian-sdk-key
SOOM_SDK_API_KEY=change-me-soom-sdk-key
MOYO_SDK_API_KEY=change-me-moyo-sdk-key

# Meta Pixel. Leave disabled locally to avoid sending test traffic.
META_PIXEL_ENABLED=false
META_PIXEL_ID=your-meta-pixel-id
